{
  "name": "ai-rules",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "dev": "pnpm -r --parallel --filter './packages/**' build --watch",
    "clean": "rimraf --glob packages/*/dist temp node_modules/.cache/.eslintcache node_modules/.cache/.prettiercache docs/.vitepress/dist",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "typecheck": "tsc --incremental --noEmit",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache .",
    "lint-fix": "eslint --fix --cache --cache-location node_modules/.cache/.eslintcache .",
    "format": "prettier --write --cache --cache-location node_modules/.cache/.prettiercache .",
    "format-check": "prettier --check --cache --cache-location node_modules/.cache/.prettiercache .",
    "test": "vitest run",
    "test-unit": "vitest run --project unit",
    "test-e2e": "vitest run --project e2e",
    "test-coverage": "vitest run --project unit --coverage",
    "release": "node scripts/release.mjs release",
    "release:dry": "node scripts/release.mjs release --bump patch --dry-run --skipPrompts",
    "release:precheck": "node scripts/release.mjs precheck --strict",
    "release:readiness": "node scripts/release.mjs readiness --allow-zero",
    "release:plan": "node scripts/release.mjs plan",
    "release:publish": "node scripts/release.mjs publish",
    "release:version": "node scripts/release.mjs version",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@baicie/release": "^0.3.3",
    "@baicie/scripts": "^0.1.2",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck",
    "commit-msg": "node -e \"import('@baicie/scripts').then(m => m.verifyCommit())\""
  },
  "lint-staged": {
    "*.{js,json,md,ts,tsx,yaml,yml}": [
      "prettier --write --cache --cache-location node_modules/.cache/.prettiercache"
    ],
    "*.ts?(x)": [
      "eslint --fix --cache --cache-location node_modules/.cache/.eslintcache",
      "prettier --parser=typescript --write --cache --cache-location node_modules/.cache/.prettiercache"
    ]
  }
}
