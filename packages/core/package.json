{
  "name": "@baicie/airules-core",
  "type": "module",
  "version": "0.0.1-beta.0",
  "description": "Core installer, source resolver, registry, lockfile, and pack tooling for airules.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baicie/ai-rules",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@baicie/airules-schema": "workspace:*",
    "jiti": "^2.7.0",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "private": false,
  "types": "./dist/index.d.ts"
}
